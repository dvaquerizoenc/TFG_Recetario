<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center"
    android:windowBackground="@android:color/transparent"
    android:background="@android:color/transparent">

    <androidx.cardview.widget.CardView
        android:layout_marginHorizontal="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="36dp"
        app:cardElevation="8dp"
        android:backgroundTint="@color/iconFill">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="24dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/dialog_delete_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/epilogue_bold"
                android:textColor="@color/titulos"
                android:textSize="18sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/dialog_delete_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/titulos"
                android:textSize="16sp"
                android:fontFamily="@font/epilogue_regular"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/dialog_delete_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/dialog_delete_item">

                <Button
                    android:id="@+id/cancel_btn_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/transparente"
                    android:fontFamily="@font/epilogue_bold"
                    android:text="@string/cancel_btn"
                    android:textColor="@color/titulos"
                    android:textSize="14sp"
                    app:strokeColor="@color/titulos"
                    app:strokeWidth="2dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/delete_btn_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/transparente"
                    android:fontFamily="@font/epilogue_bold"
                    android:text="@string/btn_delete_item"
                    android:textColor="@color/titulos"
                    android:textSize="14sp"
                    app:strokeColor="@color/titulos"
                    app:strokeWidth="2dp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>